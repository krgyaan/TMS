<div style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #222;">
    <p>Dear Team Leader,</p>

    {{#if data.is_recommended}}
        <p>
            Please find the tender info sheet filled by TE. Kindly review the
            details and decide whether the tender should be bid.
        </p>
    {{else}}
        <p>
            Please find the tender info sheet marked as
            <b>Not Recommended</b> by TE. Kindly review the rejection details
            and take your decision.
        </p>
    {{/if}}

    <table width="100%" cellpadding="6" cellspacing="0"
        style="border: 1px solid #444; border-collapse: collapse; margin-bottom: 16px;">
        <tbody>
            <tr>
                <th style="border: 1px solid #444; text-align: left; width: 16%; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Organization</th>
                <td style="border: 1px solid #444; text-align: left; width: 17%; padding: 8px;">{{data.organization}}</td>
                <th style="border: 1px solid #444; text-align: left; width: 17%; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Website</th>
                <td style="border: 1px solid #444; text-align: left; width: 17%; padding: 8px;">{{data.website}}</td>
                <th style="border: 1px solid #444; text-align: left; width: 16%; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Tender Name</th>
                <td style="border: 1px solid #444; text-align: left; width: 17%; padding: 8px;">{{data.tender_name}}</td>
            </tr>
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Tender No</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.tender_no}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Bid Due Date &amp; Time</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.dueDate}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Recommendation By TE</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.recommendation_by_te}}</td>
            </tr>
        </tbody>
    </table>

    {{#if data.is_recommended}}

    <table width="100%" cellpadding="6" cellspacing="0"
        style="border: 1px solid #444; border-collapse: collapse; margin-bottom: 16px;">
        <tbody>
            <tr>
                <td colspan="6" style="border: 1px solid #444; text-align: center;
                    background-color: #2c3e50; color: #fff; padding: 10px;">
                    <b>Tender Information</b>
                </td>
            </tr>

            <!-- Processing Fee -->
            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Processing Fee Required</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.processing_fee_required}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Processing Fee Amount</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.processing_fee_required_bool}}{{data.processing_fee_amount}}{{else}}—{{/if}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Processing Fee Mode</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.processing_fee_required_bool}}{{data.processing_fee_modes}}{{else}}—{{/if}}</td>
            </tr>

            <!-- Tender Fee -->
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Tender Fee Required</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.tender_fee_required}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Tender Fee Amount</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.tender_fee_required_bool}}{{data.tender_fees}}{{else}}—{{/if}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Tender Fee Mode</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.tender_fee_required_bool}}{{data.tender_fees_in_form_of}}{{else}}—{{/if}}</td>
            </tr>

            <!-- EMD -->
            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">EMD Required</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.emd_required}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">EMD Amount</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.emd_required_bool}}{{data.emd}}{{else}}—{{/if}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">EMD Mode</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.emd_required_bool}}{{data.emd_in_form_of}}{{else}}—{{/if}}</td>
            </tr>

            <!-- Tender Value / Bid / OEM -->
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Tender Value (GST Incl.)</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.tender_value}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">OEM Experience</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.oem_experience}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Bid Validity</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.bid_validity}}</td>
            </tr>

            <!-- RA / MAF / Commercial -->
            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Commercial Evaluation</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.commercial_evaluation}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Reverse Auction Applicable</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.ra_applicable}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">MAF Required</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.maf_required}}</td>
            </tr>

            <!-- Delivery -->
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Delivery Time (Supply/Total)</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.delivery_time}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Delivery Time (I&amp;C) Inclusive</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.delivery_time_ic_inclusive}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Delivery Time (I&amp;C)</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">
                    {{#if data.delivery_time_ic_inclusive_bool}}
                        Inclusive in Supply/Total time
                    {{else}}
                        {{data.delivery_time_ic}}
                    {{/if}}
                </td>
            </tr>

            <!-- PBG -->
            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">PBG Required</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.pbg_required}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">PBG Form</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.pbg_required_bool}}{{data.pbg_form}}{{else}}—{{/if}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">PBG Duration</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.pbg_required_bool}}{{data.pbg_duration}}{{else}}—{{/if}}</td>
            </tr>
            
            <!-- Payment Terms -->
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Payment Terms (Supply)</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.payment_terms}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Payment Terms (I&amp;C)</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.payment_terms_ic}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">SD Required</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.sd_required}}</td>
            </tr>

            <!-- SD Details -->
            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">SD Form</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.sd_required_bool}}{{data.sd_form}}{{else}}—{{/if}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">SD Percentage</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.sd_required_bool}}{{data.sd_percentage}}{{else}}—{{/if}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">SD Duration</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.sd_required_bool}}{{data.sd_duration}}{{else}}—{{/if}}</td>
            </tr>

            <!-- LD -->
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">LD Applicable</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.ld_required}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">LD % Per Week</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.ld_percentage}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Max LD %</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.max_ld}}</td>
            </tr>

            <!-- Physical Docs -->
            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Physical Docs Required</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.phydocs_submission_required}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Physical Document Type</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.phydocs_required_bool}}{{data.phydocs_doc_type}}{{else}}—{{/if}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Submission Deadline</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.phydocs_required_bool}}{{data.phydocs_submission_deadline}}{{else}}—{{/if}}</td>
            </tr>
        </tbody>
    </table>

    <!-- Eligibility & Financial Criteria -->
    <table width="100%" cellpadding="6" cellspacing="0"
        style="border: 1px solid #444; border-collapse: collapse; margin-bottom: 16px;">
        <tbody>
            <tr>
                <td colspan="6" style="border: 1px solid #444; text-align: center;
                    background-color: #2c3e50; color: #fff; padding: 10px;">
                    <b>Eligibility &amp; Financial Criteria</b>
                </td>
            </tr>

            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Eligibility Criterion (Age)</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.eligibility_criterion}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Work Value Type</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.work_value_type}}</td>
            </tr>

            {{#if data.custom_eligibility_criteria}}
            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Custom Eligibility Criteria</th>
                <td colspan="5" style="border: 1px solid #444; text-align: left; padding: 8px;">
                    <pre style="white-space: pre-wrap; margin: 0;">{{data.custom_eligibility_criteria}}</pre>
                </td>
            </tr>
            {{else}}
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">1 Work Value</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.work_value1}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">2 Work Value</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.work_value2}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">3 Work Value</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.work_value3}}</td>
                <td colspan="2" style="border: 1px solid #444;"></td>
            </tr>
            {{/if}}

            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Annual Avg. Turnover</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.aat_display}}</td>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.aat_amt}}{{data.aat_amt}}{{else}}—{{/if}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Working Capital</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.wc_display}}</td>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.wc_amt}}{{data.wc_amt}}{{else}}—{{/if}}</td>
            </tr>
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Net Worth</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.nw_display}}</td>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.nw_amt}}{{data.nw_amt}}{{else}}—{{/if}}</td>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Solvency Certificate</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.sc_display}}</td>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{#if data.sc_amt}}{{data.sc_amt}}{{else}}—{{/if}}</td>
            </tr>
        </tbody>
    </table>

    <!-- Documents -->
    <table width="100%" cellpadding="6" cellspacing="0"
        style="border: 1px solid #444; border-collapse: collapse; margin-bottom: 16px;">
        <tbody>
            <tr>
                <td colspan="2" style="border: 1px solid #444; text-align: center;
                    background-color: #2c3e50; color: #fff; padding: 10px;">
                    <b>Documents</b>
                </td>
            </tr>
            <tr>
                <th style="border: 1px solid #444; text-align: left; width: 25%; background-color: #e8e8e8; font-weight: bold; padding: 8px;">
                    Technical Eligibility Documents
                </th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">
                    <ul style="margin: 0; padding-left: 18px;">
                        {{#each data.te_docs}}
                            <li>
                                {{#if this.path}}
                                    <a href="{{data.fileBaseUrl}}/tender-files/serve/{{this.path}}" target="_blank" style="color: #0066cc; text-decoration: underline;">{{this.name}}</a>
                                {{else}}
                                    {{this.name}}
                                {{/if}}
                            </li>
                        {{else}}
                            <li>None</li>
                        {{/each}}
                    </ul>
                </td>
            </tr>
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Tender Documents</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">
                    <ul style="margin: 0; padding-left: 18px;">
                        {{#each data.tender_docs}}
                            <li>
                                <a href="{{data.fileBaseUrl}}/tender-files/serve/{{this}}" target="_blank" style="color: #0066cc; text-decoration: underline;">{{this}}</a>
                            </li>
                        {{else}}
                            <li>None</li>
                        {{/each}}
                    </ul>
                </td>
            </tr>
            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">
                    Commercial Eligibility Documents
                </th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">
                    <ul style="margin: 0; padding-left: 18px;">
                        {{#each data.ce_docs}}
                            <li>
                                {{#if this.path}}
                                    <a href="{{data.fileBaseUrl}}/tender-files/serve/{{this.path}}" target="_blank" style="color: #0066cc; text-decoration: underline;">{{this.name}}</a>
                                {{else}}
                                    {{this.name}}
                                {{/if}}
                            </li>
                        {{else}}
                            <li>None</li>
                        {{/each}}
                    </ul>
                </td>
            </tr>
        </tbody>
    </table>

    <!-- Client Details -->
    <table width="100%" cellpadding="6" cellspacing="0"
        style="border: 1px solid #444; border-collapse: collapse; margin-bottom: 16px;">
        <thead>
            <tr>
                <th colspan="4" style="border: 1px solid #444; text-align: center;
                    background-color: #2c3e50; color: #fff; padding: 10px;">
                    Client Details
                </th>
            </tr>
            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Name</th>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Designation</th>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Email</th>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Phone</th>
            </tr>
        </thead>
        <tbody>
            {{#each data.clients}}
            <tr>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{this.client_name}}</td>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{this.client_designation}}</td>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{this.client_email}}</td>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{this.client_mobile}}</td>
            </tr>
            {{else}}
            <tr>
                <td colspan="4" style="border: 1px solid #444; text-align: center; padding: 8px;">
                    No client details available
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <!-- Courier Address -->
        <table width="100%" cellpadding="6" cellspacing="0"
            style="border: 1px solid #444; border-collapse: collapse; margin-bottom: 16px;">
            <tbody>
                <tr>
                    <td colspan="4" style="border: 1px solid #444; text-align: center;
                        background-color: #2c3e50; color: #fff; padding: 10px;">
                        <b>Courier Details</b>
                    </td>
                </tr>
                {{#if data.courier_name}}
                    <tr>
                        <th style="border: 1px solid #444; text-align: left; width: 20%; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Name</th>
                        <td style="border: 1px solid #444; text-align: left; width: 30%; padding: 8px;">{{data.courier_name}}</td>
                        <th style="border: 1px solid #444; text-align: left; width: 20%; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Phone</th>
                        <td style="border: 1px solid #444; text-align: left; width: 30%; padding: 8px;">{{data.courier_phone}}</td>
                        <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">City</th>
                        <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.courier_city}}</td>
                    </tr>
                    <tr style="background-color: #f9f9f9;">
                        <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">State</th>
                        <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.courier_state}}</td>
                        <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Pincode</th>
                        <td style="border: 1px solid #444; text-align: left; padding: 8px;">{{data.courier_pincode}}</td>
                    </tr>
                {{else}}
                    <tr>
                        <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Address</th>
                        <td style="border: 1px solid #444; text-align: left; padding: 8px;" colspan="3">
                            {{data.courier_address}}
                        </td>
                    </tr>
                {{/if}}
            </tbody>
        </table>

    <!-- TE Final Remark -->
    {{#if data.te_final_remark}}
        <p><b>TE Final Remark:</b></p>
        <pre style="white-space: pre-wrap; background-color: #f5f5f5; padding: 10px;
            border: 1px solid #444; border-radius: 4px;">{{data.te_final_remark}}</pre>
    {{/if}}

    {{else}}

    <table width="100%" cellpadding="6" cellspacing="0"
        style="border: 1px solid #444; border-collapse: collapse; margin-bottom: 16px;">
        <tbody>
            <tr>
                <td colspan="2" style="border: 1px solid #444; text-align: center;
                    background-color: #c0392b; color: #fff; padding: 10px;">
                    <b>Rejection Details</b>
                </td>
            </tr>
            <tr>
                <th style="border: 1px solid #444; text-align: left; width: 25%; background-color: #e8e8e8; font-weight: bold; padding: 8px;">
                    Rejection Reason
                </th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">
                    {{data.recommendation_reason}}
                </td>
            </tr>
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">Rejection Remarks</th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">
                    <pre style="white-space: pre-wrap; margin: 0;">{{data.rejection_remarks}}</pre>
                </td>
            </tr>
            <tr>
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">
                    Proof of Rejection
                </th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">
                    <ul style="margin: 0; padding-left: 18px;">
                        {{#each data.rejection_proofs}}
                            <li>
                                <a href="{{data.fileBaseUrl}}/tender-files/serve/{{this.path}}" target="_blank" style="color: #0066cc; text-decoration: underline;">View Proof</a>
                            </li>
                        {{else}}
                            <li>No proof attached</li>
                        {{/each}}
                    </ul>
                </td>
            </tr>
            <tr style="background-color: #f9f9f9;">
                <th style="border: 1px solid #444; text-align: left; background-color: #e8e8e8; font-weight: bold; padding: 8px;">
                    Tender Documents
                </th>
                <td style="border: 1px solid #444; text-align: left; padding: 8px;">
                    <ul style="margin: 0; padding-left: 18px;">
                        {{#each data.tender_docs}}
                            <li>
                                <a href="{{data.fileBaseUrl}}/tender-files/serve/{{this}}" target="_blank" style="color: #0066cc; text-decoration: underline;">{{this}}</a>
                            </li>
                        {{else}}
                            <li>None</li>
                        {{/each}}
                    </ul>
                </td>
            </tr>
        </tbody>
    </table>

    {{/if}}

    <!-- Footer -->
    <p>
        Please take your decision using the form link:
        <a href="{{data.link}}">click here</a>.
        {{#if data.is_recommended}}
            Please decide within the next 24 hours so that I can prepare and
            bid this tender on time.
        {{else}}
            Please review the rejection details and decide within the next
            24 hours.
        {{/if}}
    </p>

    <br />
    <b>Regards,</b><br />
    {{data.assignee}}
</div>