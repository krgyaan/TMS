<div style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #222;">
    <p>Dear {{data.teName}},</p>
    <p>
        The costing of the Tender
        {{data.tenderName}}, has been checked and rejected for bidding. Please review the tender documents with a deep study of the technical documents, scope of work, and the
        quotations received from the vendor. Please submit the costing sheet immediately.
    </p>
    <p>Link: <a href="{{data.costingSheetLink}}">Costing sheet</a></p>

    {{#if data.details}}
    <table width="100%" cellpadding="6" cellspacing="0"
        style="border: 1px solid #444; border-collapse: collapse; margin-bottom: 16px;">
        <thead>
            <tr>
                <th style="border: 1px solid #444; background-color: #c0392b; color: #fff; padding: 8px; text-align: left;">#</th>
                <th style="border: 1px solid #444; background-color: #c0392b; color: #fff; padding: 8px; text-align: left;">Rejection Reason</th>
            </tr>
        </thead>
        <tbody>
            {{#each data.details}}
            <tr>
                <td style="border: 1px solid #444; padding: 8px; text-align: left;">{{this.index}}</td>
                <td style="border: 1px solid #444; padding: 8px; text-align: left;">{{this.rejectionReason}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{/if}}

    <p>
        The tender due date and time is
        {{data.dueDate}}
        at
        {{data.dueTime}}. Please submit the tender at least 48 hours before the tender due date and time.
    </p>
    <p>Best Regards,<br />{{data.tlName}}</p>
</div>