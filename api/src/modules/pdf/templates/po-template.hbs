<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Purchase Order</title>
</head>
<body style="font-family: Arial, sans-serif; font-size: 12px; color: #000; margin: 20px;">
    
    <!-- Header -->
    <table style="width: 100%; border-collapse: collapse; margin-bottom: 10px; border: 1px solid #000;">
      <thead>
        <tr>
            <th colspan="3" style="border: 1px solid #000; padding: 8px; text-align: center; font-size: 16px;">
                PURCHASE ORDER
            </th>
        </tr>
      </thead>
      <tbody>
        <tr>
            <td style="width: 15%; vertical-align: top; border: 1px solid #000; padding: 8px;">
                <img src="data:image/png;base64,{{ img_logo_base64 }}" alt="Volks Energie Logo" style="height: 60px;">
            </td>

            <td style="width: 40%; vertical-align: top; border: 1px solid #000; padding: 8px;">
                <strong>Volks Energie Pvt. Ltd.</strong><br>
                B-1/D8, 2nd floor, Mohan Cooperative Industrial Estate,<br>
                New Delhi - 110044<br>
                PAN No.: AADCV9396C<br>
                GST No.: 07AADCV9396C1ZZ
            </td>

            <td style="width: 45%; vertical-align: top; border: 1px solid #000; padding: 8px;">
                <strong>Date:</strong> {{formatDate po_date}}<br>
                <strong>PO No.:</strong> {{po_number}}<br>
                <strong>Project Name:</strong> {{project_name}}<br>
                <strong>Contact Person:</strong> {{oe_name}}<br>
                <strong>Contact No.:</strong> {{oe_number}}<br>
                <strong>Contact Email:</strong> {{oe_email}}
            </td>
        </tr>

        <tr>
            <td colspan="2" style="width: 50%; vertical-align: top; border: 1px solid #000; padding: 8px;">
                <strong>Vendor Details:</strong><br>
                {{seller_name}}<br>
                {{seller_address}}<br>
                PAN No.: {{seller_pan}}<br>
                GST No.: {{seller_gst}}<br>
                MSME No.: {{#if seller_msme}}{{seller_msme}}{{else}}Non MSME Vendor{{/if}}
            </td>

            <td style="width: 50%; vertical-align: top; border: 1px solid #000; padding: 8px;">
                <strong>Shipping Details:</strong><br>
                {{shipping_to_name}}<br>
                {{shipping_to_address}}<br>
                {{#if shipping_to_pan}}
                PAN No.: {{shipping_to_pan}}<br>
                {{/if}}
                {{#if shipping_to_gst}}
                GST No.: {{shipping_to_gst}}
                {{/if}}
            </td>
        </tr>
      </tbody>
    </table>

    <!-- Intro -->
    <p>
        This is in reference to your offer and subsequent discussion with you. 
        We are pleased to place this PO to your company {{seller_name}}
    </p>

    <!-- Items Table -->
    <table style="width: 100%; border-collapse: collapse; border: 1px solid #000; margin-bottom: 10px;">
        <tr>
            <th style="border: 1px solid #000; padding: 5px;">Sr. No</th>
            <th style="border: 1px solid #000; padding: 5px;">Item Description</th>
            <th style="border: 1px solid #000; padding: 5px;">Quantity (Nos)</th>
            <th style="border: 1px solid #000; padding: 5px;">Rate (Rs.)</th>
            <th style="border: 1px solid #000; padding: 5px;">Amount</th>
            <th style="border: 1px solid #000; padding: 5px;">GST Rate</th>
            <th style="border: 1px solid #000; padding: 5px;">GST Amount</th>
            <th style="border: 1px solid #000; padding: 5px;">Total</th>
        </tr>

        {{#each items}}
        <tr>
            <td style="border: 1px solid #000; padding: 5px;">{{inc @index}}</td>
            <td style="border: 1px solid #000; padding: 5px;">{{description}}</td>
            <td style="border: 1px solid #000; padding: 5px; text-align: right;">{{quantity}}</td>
            <td style="border: 1px solid #000; padding: 5px; text-align: right;">{{formatCurrency rate}}</td>
            <td style="border: 1px solid #000; padding: 5px; text-align: right;">{{formatCurrency amount}}</td>
            <td style="border: 1px solid #000; padding: 5px; text-align: right;">{{gst_rate}}%</td>
            <td style="border: 1px solid #000; padding: 5px; text-align: right;">{{formatCurrency gst_amount}}</td>
            <td style="border: 1px solid #000; padding: 5px; text-align: right;">{{formatCurrency total}}</td>
        </tr>
        {{/each}}

        <!-- Totals -->
        <tr>
            <td colspan="5" style="border: 1px solid #000; padding: 5px; text-align: right;">
                <strong>Total Amount</strong>
            </td>
            <td style="border: 1px solid #000; padding: 5px; text-align: right;">{{formatCurrency total_amount}}</td>
            <td></td>
            <td style="border: 1px solid #000; padding: 5px; text-align: right;">{{formatCurrency total_gst_amt}}</td>
            <td style="border: 1px solid #000; padding: 5px; text-align: right;">{{formatCurrency grand_total}}</td>
        </tr>
    </table>

    <p><strong>Total Amount (In Words):</strong> {{grand_total_in_words}}</p>

    <!-- Terms -->
    <div>
        <strong>Terms and conditions:</strong><br>
        {{#each terms_and_conditions}}
        <b>{{this.field}}:</b> {{this.value}}.<br>
        {{/each}}
    </div>

    <p style="margin-top: 20px;">
        Test certificate and invoice with machine serial no. need to be shared on {{test_certificate_email}}.
    </p>

    <!-- Footer -->
    <p style="margin-top: 20px; text-align: center;">
        *** This is electronically generated document. It does not require any signature from M/s. Volks Energie Pvt. Ltd. ***
    </p>

    <table style="width: 100%; margin-top: 40px;">
        <tr style="text-align: center;">
            <td style="text-align: center;">
                Read understood and unconditionally accepted for and on behalf of
            </td>
        </tr>
        <tr>
            <td style="text-align: left;">
                For M/s Volks Energie Pvt Ltd<br>
                <img src="data:image/png;base64,{{img_sign_po_base64}}" style="height: 80px;">
                <br>Authorized Signatory
            </td>
            <td style="text-align: right;">
                For M/s {{seller_name}}<br><br><br><br><br><br><br><br>
                Authorized Signatory
            </td>
        </tr>
    </table>

</body>
</html>